# Copy this file to .env and fill in real values.
# .env is gitignored and should never be committed.

# Supabase project URL — found in Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase publishable (anon) key — found in Settings → API
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase service role key — found in Settings → API
# Used only by dev seed scripts (npm run seed / npm run seed:reset).
# Never use the VITE_ prefix for this key — it must never reach the browser.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# OpenAI API key — used only by seed scripts (npm run seed:mentors).
# Never use the VITE_ prefix — must never reach the browser.
OPENAI_API_KEY=sk-proj-...

# Dev mode — controls the persona switcher (DEV button) and the dev login
# section on the landing page.
#
#   true  → DEV button appears in the UI, landing page shows the GitHub/Dev
#            Mode toggle so you can sign in as any seed persona instantly.
#   false → All dev UI is excluded from the bundle entirely. The only way to
#            log in is through real GitHub OAuth. Use this for production.
#
# Local development: set to true
# Production (Cloudflare Pages env vars): set to false or omit
VITE_ENABLE_DEV_MODE=true

# ── Feature flags ──────────────────────────────────────────────────────────────
# Each flag controls whether an entire feature surface is visible in the app.
# When false: nav links are removed, dashboard sections are hidden, and direct
# URL access redirects to /. The underlying code, routes, and database logic
# are all preserved — only the UI entry points are gated.
#
# These are baked into the JS bundle at build time by Vite. To change them on
# the live site, update the corresponding environment variable in Cloudflare
# Pages (Settings → Environment variables) and trigger a new deployment.
#
# Fund requests, budget tracker, and request history
VITE_ENABLE_BUDGETING=true
# Mentor matching, session requests, and match history
VITE_ENABLE_MENTORSHIP=true
# NCAA transcript upload and eligibility assessment
VITE_ENABLE_ELIGIBILITY=true

