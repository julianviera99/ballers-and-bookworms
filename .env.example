# Copy this file to .env and fill in real values.
# .env is gitignored and should never be committed.

# Supabase project URL — found in Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase publishable (anon) key — found in Settings → API
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase service role key — found in Settings → API
# Used only by dev seed scripts (npm run seed / npm run seed:reset).
# Never use the VITE_ prefix for this key — it must never reach the browser.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
